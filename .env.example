# TMDB v3 API key. Vite client variables are visible in the browser.
VITE_TMDB_API_KEY=your_tmdb_api_key

# Optional JSON endpoint for live event management.
# Leave empty to use public/events.json.
VITE_EVENTS_API_URL=

# Optional SceneYou API server.
# Leave empty to keep LocalStorage-only demo mode.
VITE_API_URL=
